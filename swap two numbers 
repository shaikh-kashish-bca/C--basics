#include <stdio.h>

int main() {
    int a, b, temp;
    
    printf("Enter first number: ");
    scanf("%d", &a);
    
    printf("Enter second number: ");
    scanf("%d", &b);
    
    // SWAPPING LOGIC
    temp = a;  // Step 1: a ko temp mein rakha
    a = b;     // Step 2: b ko a mein daala  
    b = temp;  // Step 3: temp ko b mein daala
    
    printf("After Swap: a = %d, b = %d", a, b);
    
    return 0;
}